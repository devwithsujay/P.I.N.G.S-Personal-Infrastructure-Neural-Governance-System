# P.I.N.G.S Core v2 Environment Variables

BRAIN_SECRET_KEY=change-me-to-a-secure-random-string
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxx
MODEL_VISION=meta/llama-3.2-11b-vision-instruct
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
DEFAULT_ZEN_MODEL=opencode/mimo-v2.5-free
OPENCODE_CONFIG_PATH=/app/opencode.json
OPENCODE_SERVER_URL=http://pings-opencode:4096
ZEN_API_KEY=

TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=

SEARXNG_URL=http://pings-searxng:8080
NTFY_URL=http://pings-ntfy:80
NTFY_TOPIC=pings

# SSH Host Access
SSH_HOST=192.168.1.100
SSH_PORT=22
SSH_USER=root
SSH_AUTH_TYPE=key
SSH_KEY_PATH=/app/keys/id_rsa
SSH_PASSWORD=

# Research Pipeline Settings
MIN_SOURCES_PER_SUBTOPIC=15
MIN_WORDS_PER_SECTION=500
MIN_WORDS_TOTAL=8000
MAX_SEARCH_REFORMULATIONS=6
MAX_SECTION_REWRITE_ATTEMPTS=3
FETCH_TIMEOUT_SECONDS=15
FETCH_CONCURRENCY=5

PROACTIVE_INTERVAL_MINUTES=30
JOURNAL_PATH=/app/persona/JOURNAL.md

TOOL_REGISTRY_ENABLED=true

CHROMA_URL=http://pings-chroma:8000
SQLITE_DB_PATH=/app/data/pings.db
WORKSPACE_PATH=/app/workspace
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
